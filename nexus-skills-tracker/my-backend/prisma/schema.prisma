generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  phone     String?
  photo     String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  skills    Skill[]
  roadmap   RoadmapItem[]
}


model Skill {
  id        Int      @id @default(autoincrement())
  name      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model RoadmapItem {
  id        Int      @id @default(autoincrement())
  label     String
  done      Boolean  @default(false)
  order     Int      @default(0)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}